{
  "name": "jbedu-meal-pdf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg --arm64",
    "dist:mac:x64": "electron-builder --mac dmg --x64",
    "dist:win": "electron-builder --win nsis --x64 --publish never",
    "dist:win:arm64": "electron-builder --win nsis --arm64"
  },
  "build": {
    "appId": "kr.jbedu.mealpdf",
    "productName": "전북교육연수원 식단 PDF",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "전북교육연수원 식단 PDF"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
